<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaAppMPV.ViewModels"
        xmlns:v="using:AvaloniaAppMPV.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="AvaloniaAppMPV.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}"
        Width="900" Height="600"
        MinWidth="640" MinHeight="480"
        KeyDown="OnKeyDown"
        Background="{DynamicResource VideoAreaBackground}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <DockPanel>
            <!-- Bottom control bar -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource PlayerBarBackgroundBrush}"
                    BorderBrush="{DynamicResource PlayerBarBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <DockPanel>
                    <!-- Seek slider row -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding PositionText}"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   MinWidth="45"
                                   Margin="0,0,10,0"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding DurationText}"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   MinWidth="45"
                                   Margin="10,0,0,0"/>
                        <Slider x:Name="SeekSlider"
                                Minimum="0"
                                Maximum="{Binding Duration}"
                                Value="{Binding Position}"
                                IsEnabled="{Binding HasFile}"
                                VerticalAlignment="Center"
                                ValueChanged="OnSeekSliderValueChanged"/>
                    </DockPanel>

                    <!-- Buttons row -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Left: playback buttons -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">
                            <Button Command="{Binding OpenFileCommand}"
                                    ToolTip.Tip="打开文件"
                                    MinWidth="40" MinHeight="36"
                                    Padding="10,6"
                                    HorizontalContentAlignment="Center">
                                <PathIcon Data="M5 4C3.89543 4 3 4.89543 3 6V18C3 19.1046 3.89543 20 5 20H19C20.1046 20 21 19.1046 21 18V8C21 6.89543 20.1046 6 19 6H13L11 4H5Z"
                                          Width="16" Height="16"/>
                            </Button>
                            <Button Command="{Binding PlayPauseCommand}"
                                    IsEnabled="{Binding HasFile}"
                                    ToolTip.Tip="{Binding PlayPauseText}"
                                    MinWidth="40" MinHeight="36"
                                    Padding="10,6"
                                    HorizontalContentAlignment="Center">
                                <PathIcon Data="{Binding PlayPauseIcon}"
                                          Width="16" Height="16"/>
                            </Button>
                        </StackPanel>

                        <!-- Center: time display -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TimeText}"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Right: info + volume -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <Button IsEnabled="{Binding HasFile}"
                                    Click="OnShowVideoInfoClick"
                                    ToolTip.Tip="视频信息"
                                    MinWidth="36" MinHeight="36"
                                    Padding="8,6"
                                    Margin="0,0,6,0"
                                    HorizontalContentAlignment="Center">
                                <PathIcon Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM13 17H11V11H13V17ZM13 9H11V7H13V9Z"
                                          Width="16" Height="16"/>
                            </Button>
                            <Button Command="{Binding MuteCommand}"
                                    ToolTip.Tip="{Binding MuteTooltip}"
                                    MinWidth="36" MinHeight="36"
                                    Padding="8,6"
                                    HorizontalContentAlignment="Center">
                                <PathIcon Data="{Binding VolumeIconPath}"
                                          Width="16" Height="16"/>
                            </Button>
                            <Slider x:Name="VolumeSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="{Binding Volume}"
                                    Width="100"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnVolumeSliderValueChanged"/>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Video display area -->
            <Border Background="{DynamicResource VideoAreaBackground}">
                <v:MpvVideoView x:Name="VideoView"/>
            </Border>
        </DockPanel>

        <!-- Error banner overlay -->
        <Border Background="{DynamicResource ErrorBannerBrush}"
                Padding="16,10"
                CornerRadius="0,0,8,8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                IsVisible="{Binding HasError}"
                BoxShadow="0 2 8 0 #40000000">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding DismissErrorCommand}"
                        Background="Transparent"
                        Foreground="White"
                        Padding="8,4"
                        VerticalAlignment="Center">
                    <PathIcon Data="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z"
                              Width="12" Height="12"/>
                </Button>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White"
                           FontSize="13"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </DockPanel>
        </Border>
    </Panel>

</Window>
